# =============================================================================
# Mohit Tiles & Granites — Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.
# =============================================================================

# Neon PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Admin seed credentials (used only by prisma/seed.ts)
ADMIN_EMAIL="admin@mohittiles.com"
ADMIN_PASSWORD="ChangeMe_StrongPassword123!"
ADMIN_NAME="Store Admin"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# Optional: Upstash Redis for rate limiting (falls back to in-memory if unset)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Public site URL (for sitemap, canonical URLs, OG tags)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Mohit Tiles & Granites"
