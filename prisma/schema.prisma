generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CUSTOMER
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

enum BannerType {
  HERO
  PROMO
  OFFER
  CATEGORY
}

model Store {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  products        Product[]
  categories      Category[]
  brands          Brand[]
  contactDetails  ContactDetails?
  heroBanners     HeroBanner[]
  testimonials    Testimonial[]
  faqs            FAQ[]
  offers          Offer[]
  services        Service[]
  galleryImages   GalleryImage[]
  clientLogos     ClientLogo[]
  inquiries       ContactInquiry[]
  siteSettings    SiteSetting[]
  homepageBlocks  HomepageBlock[]

  @@index([slug])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(ADMIN)
  isActive     Boolean  @default(true)
  storeId      String?
  store        Store?   @relation(fields: [storeId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@index([storeId])
  @@index([role])
}

model Brand {
  id          String    @id @default(cuid())
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  logoUrl     String?
  website     String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([storeId, slug])
  @@index([storeId, isActive])
  @@index([name])
}

model Category {
  id          String     @id @default(cuid())
  storeId     String
  store       Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  imageUrl    String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  seoTitle    String?
  seoDescription String?
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([storeId, slug])
  @@index([storeId, isActive])
  @@index([parentId])
  @@index([name])
}

model Product {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  brandId       String?
  brand         Brand?   @relation(fields: [brandId], references: [id])

  name          String
  slug          String
  sku           String?
  description   String?  @db.Text
  shortDescription String?
  material      String?
  finish        String?
  color         String?
  dimensions    String?
  size          String?
  thickness     String?
  unit          String   @default("piece")

  mrp           Decimal  @db.Decimal(12, 2)
  price         Decimal  @db.Decimal(12, 2)
  discountPercent Decimal? @db.Decimal(5, 2)
  currency      String   @default("INR")

  stockQuantity Int      @default(0)
  lowStockAt    Int      @default(5)

  isPublished   Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  isNewArrival  Boolean  @default(false)
  sortOrder     Int      @default(0)

  specifications Json?
  collection    String?
  tags          String[]

  seoTitle      String?
  seoDescription String?
  seoKeywords   String?

  images        ProductImage[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([storeId, slug])
  @@index([storeId, isPublished])
  @@index([categoryId])
  @@index([brandId])
  @@index([isFeatured])
  @@index([isNewArrival])
  @@index([price])
  @@index([material])
  @@index([finish])
  @@index([color])
  @@index([size])
  @@index([name])
  @@index([collection])
}

model ProductImage {
  id           String   @id @default(cuid())
  productId    String
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url          String
  publicId     String?
  thumbnailUrl String?
  alt          String?
  sortOrder    Int      @default(0)
  width        Int?
  height       Int?
  createdAt    DateTime @default(now())

  @@index([productId, sortOrder])
}

model HeroBanner {
  id          String     @id @default(cuid())
  storeId     String
  store       Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  type        BannerType @default(HERO)
  title       String
  subtitle    String?
  imageUrl    String
  publicId    String?
  linkUrl     String?
  ctaText     String?
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([storeId, type, isActive])
  @@index([sortOrder])
}

model Testimonial {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  role      String?
  company   String?
  content   String   @db.Text
  rating    Int      @default(5)
  avatarUrl String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, isActive])
}

model FAQ {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  question  String
  answer    String   @db.Text
  category  String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, isActive])
}

model ContactDetails {
  id              String  @id @default(cuid())
  storeId         String  @unique
  store           Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  businessName    String
  addressLine1    String
  addressLine2    String?
  city            String
  state           String
  postalCode      String?
  country         String  @default("India")
  phonePrimary    String
  phoneSecondary  String?
  whatsapp        String?
  email           String
  emailSecondary  String?
  mapEmbedUrl     String?
  latitude        Float?
  longitude       Float?
  openTime        String  @default("10:00")
  closeTime       String  @default("20:00")
  openDays        String  @default("Everyday")
  facebookUrl     String?
  instagramUrl    String?
  youtubeUrl      String?
  twitterUrl      String?
  linkedinUrl     String?
  aboutHtml       String? @db.Text
  aboutTitle      String?
  legacyText      String? @db.Text
}

model ContactInquiry {
  id        String        @id @default(cuid())
  storeId   String
  store     Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  email     String?
  subject   String?
  message   String        @db.Text
  productId String?
  status    InquiryStatus @default(NEW)
  notes     String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([storeId, status])
  @@index([createdAt])
}

model Offer {
  id          String    @id @default(cuid())
  storeId     String
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title       String
  description String?   @db.Text
  imageUrl    String?
  discountText String?
  linkUrl     String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([storeId, isActive])
}

model Service {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title       String
  description String?  @db.Text
  iconUrl     String?
  imageUrl    String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId, isActive])
}

model GalleryImage {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title     String?
  imageUrl  String
  publicId  String?
  category  String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, category, isActive])
}

model ClientLogo {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  imageUrl  String
  linkUrl   String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, isActive])
}

model HomepageBlock {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  key       String
  title     String?
  subtitle  String?
  body      String?  @db.Text
  imageUrl  String?
  linkUrl   String?
  metadata  Json?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, key])
  @@index([storeId, isActive])
}

model SiteSetting {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  key       String
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, key])
  @@index([storeId])
}
